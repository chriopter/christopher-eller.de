{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- $sections := slice "photos" "links" "posts" "projects" -}}
{{- range where .Site.Pages "Section" "in" $sections -}}
    {{- $pages = $pages | append . -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- $pages = $pages | first $limit -}}
<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ .Site.Title }}</title>
  <link href="{{ .Permalink }}feed.xml" rel="self"/>
  <link href="{{ .Permalink }}" rel="alternate" type="text/html"/>
  <updated>{{ now.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</updated>
  <id>{{ .Permalink }}</id>
  <author>
    <name>{{ .Site.Title }}</name>
  </author>
  <generator uri="https://gohugo.io/" version="{{ hugo.Version }}">Hugo</generator>
  <rights>© {{ now.Year }} {{ .Site.Title }}</rights>
  {{ range $pages }}
  <entry>
    <title>{{ .Title }}</title>
    <link href="{{ .Permalink }}" rel="alternate" type="text/html"/>
    <published>{{ .Date.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</published>
    <updated>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</updated>
    <id>{{ .Permalink }}</id>
    <content type="html">{{ .Content | html }}</content>
    <category term="{{ .Section }}"/>
    {{ with .Summary }}<summary>{{ . | html }}</summary>{{ end }}
  </entry>
  {{ end }}
</feed>
